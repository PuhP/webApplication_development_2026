# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string
FLASK_DEBUG=1
HOST=127.0.0.1
PORT=5000

# ─── База данных ──────────────────────────────────────────────────────────────
# Для локального запуска без Docker используйте SQLite (строка ниже).
# Файл БД создастся автоматически в папке instance/.
DATABASE_URL=sqlite:///queue_app.sqlite3

# Для запуска через Docker Compose раскомментируйте PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://queue_user:queue_password@localhost:5432/queue_db

# ─── Инициализация БД ─────────────────────────────────────────────────────────
# AUTO_INIT_DB=true  — создать таблицы при старте (если не существуют)
# RECREATE_DB=true   — УДАЛИТЬ все таблицы и создать заново (⚠ стирает все данные)
# SEED_DEMO_DATA=true — заполнить демо-данными после создания таблиц
AUTO_INIT_DB=true
RECREATE_DB=false
SEED_DEMO_DATA=true

# ─── Коды приглашений ─────────────────────────────────────────────────────────
# Студенту код не нужен. Для преподавателя и администратора:
TEACHER_INVITE_CODE=teacher2026
ADMIN_INVITE_CODE=admin2026
