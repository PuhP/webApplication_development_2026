# Основные настройки Flask
SECRET_KEY=replace-me-with-a-long-random-string
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000

# Docker Compose использует PostgreSQL ниже.
DATABASE_URL=postgresql+psycopg2://queue_user:queue_password@localhost:5432/queue_db

# Если запускаете локально без PostgreSQL, можно временно использовать SQLite:
# DATABASE_URL=sqlite:///queue_app.sqlite3

# Коды для регистрации ролей. Студенту код не нужен.
TEACHER_INVITE_CODE=teacher2026
ADMIN_INVITE_CODE=admin2026

# Автоматическое создание таблиц и демо-данных при старте приложения.
AUTO_INIT_DB=true
SEED_DEMO_DATA=true
